#include "AB0001_nrf54l15-pinctrl.dtsi"
#include <zephyr/dt-bindings/led/led.h>


// SPI Instance for digital LED's
&spi21 {
	compatible = "nordic,nrf-spim";
	status = "okay";
	pinctrl-0 = <&spi21_default>;
	pinctrl-1 = <&spi21_sleep>;
	pinctrl-names = "default", "sleep";
	
	led_strip: ws2812@0 {
		compatible = "worldsemi,ws2812-spi";
		/* SPI */
		reg = <0>; /* ignored, but necessary for SPI bindings */
		
		/* WS2812 */
		color-mapping = <LED_COLOR_ID_GREEN
						LED_COLOR_ID_RED
						LED_COLOR_ID_BLUE>;
		chain-length = <15>; /* 12 + 1 + 2 */
		spi-max-frequency = <4000000>;
		spi-one-frame = <0x70>;
		spi-zero-frame = <0x40>;
	};
};

// SPI Instance for Fingerprint, NFC Reader, UWB Chip
&spi22 {
	compatible = "nordic,nrf-spim";
	status = "okay";
	cs-gpios = 	<&gpio2 10 GPIO_ACTIVE_LOW>, 
				<&gpio2 6 GPIO_ACTIVE_LOW>,
				<&gpio2 6 GPIO_ACTIVE_LOW>;
	pinctrl-0 = <&spi22_default>;
	pinctrl-1 = <&spi22_sleep>;
	pinctrl-names = "default", "sleep";

	//NFC Reader
	st25r3911b: st25r3911b@0 {
		compatible = "st,st25r3911b";
		reg = <0>; //CS 0
		spi-max-frequency = <4000000>;
		irq-gpios = <&gpio0 1 GPIO_ACTIVE_HIGH>;
		led-nfca-gpios = <&gpio1 15 GPIO_ACTIVE_HIGH>; //not used
	};

	//Fingerprint Module
	fpc2530: fpc2530@1 {
		//compatible = "vnd,fpc2530";		
		reg = <1>; //CS 1
		spi-max-frequency = <4000000>;
	};

    //UWB Transmitter Receiver
	dwm3000tr13_spi_spi22: dwm3000tr13@2 {
		//compatible =  "vnd,dwm3000";
		reg = <2>; //CS 2
		spi-max-frequency = <4000000>;		
	};
};

// system monitor
&uart20 {
	current-speed = <115200>;
	pinctrl-0 = <&uart20_default>;
	pinctrl-1 = <&uart20_sleep>;
	pinctrl-names = "default", "sleep";
};

// pwm buzzer
/{
	pwmbuzzer {
		compatible = "pwm-leds";
		pwm0: pwm_0 {
			pwms = <&pwm20 0 PWM_MSEC(20) PWM_POLARITY_INVERTED>;
		};
	};
};

&pwm20 {	
	status = "okay";
	pinctrl-0 = <&pwm20_default>;
	pinctrl-1 = <&pwm20_sleep>;
	pinctrl-names = "default", "sleep";	
};

// pwm vibrationsmotor
&pwm21 {
	compatible = "pwm-leds";
	status = "okay";
	pinctrl-0 = <&pwm21_default>;
	pinctrl-1 = <&pwm21_sleep>;
	pinctrl-names = "default", "sleep";	
};


// cap touch feld
&i2c30 {
	compatible = "nordic,nrf-twim";
	status = "okay";
	clock-frequency = <I2C_BITRATE_FAST>;
	pinctrl-0 = <&i2c30_default>;
	pinctrl-1 = <&i2c30_sleep>;
	zephyr,concat-buf-size = <256>;	
	pinctrl-names = "default", "sleep";

	cy8cmbr3116_37_i2c30: cy8cmbr3116@37 {
        //compatible = "infineon,cy8";   // Specify device bindings/driver
        reg = <0x37>; 	// I2C address
        status = "okay"; 		
		config = [
        		FB 7F F8 7F 00 00 00 00
        		80 AA AA 2A 1F 1F 7F 64
        		64 64 64 64 64 64 64 64
        		64 64 64 7F 03 00 00 00
        		00 00 00 00 00 00 03 83
        		05 00 00 04 00 04 00 00
        		00 00 00 00 00 0F 0F 00
        		00 0F 0F 00 00 00 81 01
        		00 FF FF FF FF FF FF FF
        		FF 00 00 00 43 03 01 50
        		00 37 02 00 00 0A 00 00
        		00 00 00 00 00 00 00 00
        		00 00 00 00 00 00 00 00
        		00 00 00 00 00 00 00 00
        		00 00 00 00 00 00 00 00
        		00 00 00 00 00 00 5C 6C
		];				
    };
};

//use nfc pins as gpios
&uicr {
    nfct-pins-as-gpios;
};

//use adc
&adc {
	compatible = "vnd,adc-battery-measurement";
	en-gpios = <&gpio0 1 GPIO_ACTIVE_HIGH>;
	voltage_div = <55>; //div = 55/10 = 5.5 (float not supported)	  
};

/ {
	// used to get the node ID's with DT Macro
	aliases {
		led-strip = &led_strip;
		// vsw0 = &vsw0; //LED Versorgung
		// vsw1 = &vsw1; //NFC + FPC + UWB
		pwm0 = &pwm0;
		//isr1 = &isr1;
		cy8cmbr3116 = &cy8cmbr3116_37_i2c30;  //muss so heißen
		
		//irqpin = &irqpin;
		//cspin = &cspin;
		//pwrpin = &pwrpin;
		//rstpin = &rstpin;
	};
};

/ {
	captouch_sensor_pins {
		compatible = "gpio-leds";
		ct_irqpin: irq {
			gpios = <&gpio0 2 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
		};		
	};
};

/ {
	fingerprint_sensor_pins {
		compatible = "gpio-leds";
		fp_irqpin: irq {
			gpios = <&gpio0 0 GPIO_ACTIVE_HIGH>;
		};
		fp_cspin: cs {
			gpios = <&gpio2 6 GPIO_ACTIVE_HIGH>;
		};
		fp_pwrpin: pwr {
			gpios = <&gpio1 5 GPIO_ACTIVE_LOW>;
		};
		fp_rstpin: rst {
			gpios = <&gpio1 3 GPIO_ACTIVE_HIGH>;
		};		
	};
};

/ {
	uwb_transceiver_pins {
		compatible = "gpio-leds";
		uwb_irqpin: irq {
			gpios = <&gpio2 8 GPIO_ACTIVE_HIGH>;
		};
		uwb_cspin: cs {
			gpios = <&gpio2 7 GPIO_ACTIVE_HIGH>;
		};
		uwb_pwrpin: pwr {
			gpios = <&gpio1 5 GPIO_ACTIVE_LOW>;
		};		
	};
};

/ {
	nfc_reader_pins {
		compatible = "gpio-leds";		
		nfc_pwrpin: pwr {
			gpios = <&gpio1 5 GPIO_ACTIVE_LOW>;
		};		
	};
};

/ {powersupply_control_pins {
		compatible = "gpio-leds";
		vsw0: vsw_0 {
			gpios = <&gpio1 8 GPIO_ACTIVE_LOW>;
			label = "vled switch";
	};
		vsw1: vsw_1 {
			gpios = <&gpio1 5 GPIO_ACTIVE_LOW>;
			label = "vaux switch";
		};
	};
};

